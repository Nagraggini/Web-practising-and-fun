{
    "name": "web-practising-and-fun",
    "version": "1.0.0",
    "description": "This repository is a collection of small web development projects, experiments, and practice work.",
    "main": "index.js",
    "scripts": {
        "//build_info": "HTML összefűzés + mappák másolása a dist-be",
        "build": "npx posthtml *.html -u posthtml-include -o dist/ && npm run copy-assets",
        "//copy_info": "Segédparancs a mappák átmásolásához",
        "copy-assets": "npx shx cp -r css assets js dist/",
        "start": "servor dist 8080 --reload",
        "test": "npx playwright test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nagraggini/web-practising-and-fun.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/Nagraggini/web-practising-and-fun/issues"
    },
    "homepage": "https://github.com/Nagraggini/web-practising-and-fun#readme",
    "devDependencies": {
        "@playwright/test": "^1.44.0",
        "posthtml-cli": "^0.10.0",
        "posthtml-include": "^2.0.1",
        "servor": "^4.0.2"
    },
    "directories": {
        "doc": "docs",
        "test": "tests"
    },
    "dependencies": {
        "playwright": "^1.59.1",
        "playwright-core": "^1.59.1"
    }
}
